// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
// User model
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String?
  name         String
  role         String    // 'parent', 'child', 'teen'
  age          Int?
  family_id    String?
  avatar_url   String?
  last_chore_date DateTime?
  xp             Int       @default(0)
  level          Int       @default(1)
  streak         Int       @default(0)
  best_streak    Int       @default(0)
  email_verified      Boolean   @default(false)
  reset_token         String?
  reset_token_expires DateTime?
  verify_token         String?
  verify_token_expires DateTime?
  created_at   DateTime  @default(now())
  // Relations
  family       Family?   @relation(fields: [family_id], references: [id], onDelete: SetNull)
  assigned_chores Chore[] @relation("AssignedChores")
  created_chores Chore[]  @relation("CreatedChores")
  created_events Event[]  @relation("CreatedEvents")
  sent_messages Message[] @relation("SentMessages")
  notifications Notification[]
  created_lists List[]    @relation("CreatedLists")
  list_items_added ListItem[] @relation("AddedItems")
  list_items_checked ListItem[] @relation("CheckedItems")
  activities   Activity[] @relation("UserActivities")
  created_rewards Reward[] @relation("CreatedRewards")
  claimed_rewards Reward[] @relation("ClaimedRewards")
  approved_rewards Reward[] @relation("ApprovedRewards")
  transactions Transaction[] @relation("UserTransactions")
  budget_categories BudgetCategory[] @relation("CreatedCategories")
  projects     Project[] @relation("CreatedProjects")
  project_tasks ProjectTask[] @relation("AssignedProjectTasks")
  meals         FamilyMeal[] @relation("FamilyMealCreator")
  meals_cooked  FamilyMeal[] @relation("FamilyMealCook")
  pinned_notes  PinnedNote[] @relation("CreatedNotes")
  anniversaries Anniversary[] @relation("FamilyAnniversaries")
  locations     FamilyLocation[] @relation("UserLocations")
  pickups       Pickup[] @relation("AssignedPickups")
  pickups_created Pickup[] @relation("CreatedPickups")
  allowances_given Allowance[] @relation("AllowanceFrom")
  allowances_received Allowance[] @relation("AllowanceTo")

  @@index([family_id])
}

model Family {
  id              String    @id @default(cuid())
  name            String
  invite_code     String    @unique @default(cuid())
  subscription_tier String  @default("free") // 'free', 'premium', 'family'
  features        Json?     @default("{\"meals\":true,\"notes\":true,\"anniversaries\":true,\"locations\":false,\"pickups\":false,\"allowance\":false,\"rewards\":true,\"budget\":true,\"projects\":true,\"messages\":true,\"analytics\":true}")
  created_at      DateTime  @default(now())

  // Relations
  members       User[]
  chores        Chore[]
  events        Event[]
  messages      Message[]
  lists         List[]
  activities    Activity[]
  rewards       Reward[]
  transactions  Transaction[]
  categories    BudgetCategory[]
  projects      Project[]
  meals         FamilyMeal[]
  pinned_notes  PinnedNote[]
  anniversaries Anniversary[]
  locations     FamilyLocation[]
  pickups       Pickup[]
  allowances    Allowance[]
}

model Chore {
  id             String    @id @default(cuid())
  family_id      String
  title          String
  description    String?
  points         Int       @default(10)
  assigned_to    String    // user_id
  due_date       DateTime
  status         String    @default("pending") // 'pending', 'in_progress', 'completed', 'verified', 'overdue'
  frequency      String    @default("once") // 'once', 'daily', 'weekly', 'monthly'
  difficulty     String    @default("medium") // 'easy', 'medium', 'hard'
  photo_url      String?
  photo_verified Boolean   @default(false)
  verified_at    DateTime?
  verified_notes String?
  completed_at   DateTime?
  created_at     DateTime  @default(now())
  created_by     String    // user_id

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  assignee     User      @relation("AssignedChores", fields: [assigned_to], references: [id])
  creator      User      @relation("CreatedChores", fields: [created_by], references: [id])

  @@index([family_id])
  @@index([assigned_to])
  @@index([status])
  @@index([due_date])
  @@index([family_id, status])
  @@index([family_id, assigned_to])
}

model Event {
  id           String    @id @default(cuid())
  family_id    String
  title        String
  description  String?
  start_time   DateTime
  end_time     DateTime
  location     String?
  event_type   String    @default("other") // 'school', 'sports', 'appointment', 'family', 'work', 'other'
  is_task      Boolean   @default(false)
  project_id   String?
  recurrence   String?   // RRULE string for recurring events
  created_by   String    // user_id
  created_at   DateTime  @default(now())

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  creator      User      @relation("CreatedEvents", fields: [created_by], references: [id])
  project      Project?  @relation(fields: [project_id], references: [id], onDelete: SetNull)

  @@index([family_id])
  @@index([start_time])
  @@index([family_id, start_time])
  @@index([project_id])
}

model Message {
  id           String    @id @default(cuid())
  family_id    String
  sender_id    String
  content      String
  type         String    @default("text") // 'text', 'image', 'voice', 'announcement'
  attachments  String[]  // Array of file URLs
  read_by      String[]  // Array of user_ids who have read the message
  created_at   DateTime  @default(now())

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  sender       User      @relation("SentMessages", fields: [sender_id], references: [id])

  @@index([family_id])
  @@index([sender_id])
  @@index([created_at])
  @@index([family_id, created_at])
}

model Notification {
  id           String    @id @default(cuid())
  user_id      String
  title        String
  message      String
  type         String    // 'chore', 'event', 'message', 'system'
  read         Boolean   @default(false)
  action_url   String?   // optional link to navigate to
  created_at   DateTime  @default(now())

  // Relations
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([read])
  @@index([created_at])
  @@index([user_id, read])
}

model List {
  id           String    @id @default(cuid())
  family_id    String
  name         String
  type         String    @default("grocery") // 'grocery', 'todo', 'meal_plan', 'wishlist', 'shopping'
  description  String?
  is_repeatable Boolean  @default(false)
  last_purchased_at DateTime?
  created_by   String
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  creator      User      @relation("CreatedLists", fields: [created_by], references: [id])
  items        ListItem[]

  @@index([family_id])
  @@index([family_id, type])
}

model ListItem {
  id           String    @id @default(cuid())
  list_id      String
  content      String
  checked      Boolean   @default(false)
  quantity     Int       @default(1)
  price        Float?
  purchased    Boolean   @default(false)
  category     String?
  notes        String?
  added_by     String
  checked_by   String?
  checked_at   DateTime?
  position     Int       @default(0)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  // Relations
  list         List      @relation(fields: [list_id], references: [id], onDelete: Cascade)
  adder        User      @relation("AddedItems", fields: [added_by], references: [id])
  checker      User?     @relation("CheckedItems", fields: [checked_by], references: [id])

  @@index([list_id])
  @@index([list_id, checked])
}

model Activity {
  id           String    @id @default(cuid())
  family_id    String
  user_id      String
  type         String    // 'chore_completed', 'chore_verified', 'list_completed', 'event_created'
  title        String
  description  String?
  metadata     String?   // JSON string for extra data
  created_at   DateTime  @default(now())

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  user         User      @relation("UserActivities", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([family_id])
  @@index([family_id, created_at])
  @@index([user_id])
}

model Reward {
  id           String    @id @default(cuid())
  family_id    String
  name         String
  description  String?
  cost         Int       @default(10) // XP/points required to claim
  icon         String?   // emoji or icon identifier
  status       String    @default("available") // 'available', 'claimed', 'approved', 'redeemed'
  created_by   String
  claimed_by   String?
  claimed_at   DateTime?
  approved     Boolean   @default(false)
  approved_by  String?
  approved_at  DateTime?
  redeemed_at  DateTime?
  created_at   DateTime  @default(now())

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  creator      User      @relation("CreatedRewards", fields: [created_by], references: [id])
  claimer      User?     @relation("ClaimedRewards", fields: [claimed_by], references: [id])
  approver     User?     @relation("ApprovedRewards", fields: [approved_by], references: [id])

  @@index([family_id])
  @@index([family_id, status])
  @@index([claimed_by])
}

model Transaction {
  id           String    @id @default(cuid())
  family_id    String
  user_id      String
  amount       Float
  type         String    // 'income' or 'expense'
  category_id  String?
  description  String?
  notes        String?
  date         DateTime  @default(now())
  is_recurring Boolean   @default(false)
  recurring_interval String? // 'weekly', 'biweekly', 'monthly'
  list_item_id String?   // link to shopping list purchase
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  user         User      @relation("UserTransactions", fields: [user_id], references: [id])
  category     BudgetCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)

  @@index([family_id])
  @@index([family_id, date])
  @@index([user_id])
  @@index([category_id])
  @@index([family_id, type])
}

model BudgetCategory {
  id           String    @id @default(cuid())
  family_id    String
  name         String
  icon         String    @default("📦")
  color        String    @default("#6B7280")
  type         String    @default("expense") // 'income' or 'expense'
  budget_limit Float?
  created_by   String
  created_at   DateTime  @default(now())

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  creator      User      @relation("CreatedCategories", fields: [created_by], references: [id])
  transactions Transaction[]

  @@index([family_id])
  @@index([family_id, type])
}

model Project {
  id           String    @id @default(cuid())
  family_id    String
  name         String
  description  String?
  status       String    @default("active") // 'active', 'completed', 'archived'
  color        String    @default("#3B82F6")
  created_by   String
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  // Relations
  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  creator      User      @relation("CreatedProjects", fields: [created_by], references: [id])
  tasks        ProjectTask[]
  events       Event[]

  @@index([family_id])
  @@index([family_id, status])
}

model ProjectTask {
  id           String    @id @default(cuid())
  project_id   String
  title        String
  description  String?
  completed    Boolean   @default(false)
  assigned_to  String?
  due_date     DateTime?
  position     Int       @default(0)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  project      Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee     User?     @relation("AssignedProjectTasks", fields: [assigned_to], references: [id], onDelete: SetNull)

  @@index([project_id])
  @@index([assigned_to])
}

// Postgres-backed rate limiter (auth endpoints, etc.)
// Survives across replicas and restarts.
model RateLimitEntry {
  id           String    @id @default(cuid())
  key          String    // e.g. "login:1.2.3.4", "register:1.2.3.4"
  count        Int       @default(1)
  windowStart  DateTime
  resetAt      DateTime
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([key])
  @@index([resetAt])
}

// === New: per-family feature gates ===
// Stored on Family.features as a JSON column; this model is the default seed.

model FamilyMeal {
  id           String    @id @default(cuid())
  family_id    String
  date         DateTime
  meal_type    String    // 'breakfast' | 'lunch' | 'dinner' | 'snack'
  recipe_name  String?
  notes        String?
  cook_id      String?
  created_by   String
  created_at   DateTime  @default(now())

  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  cook         User?     @relation("FamilyMealCook", fields: [cook_id], references: [id], onDelete: SetNull)
  creator      User      @relation("FamilyMealCreator", fields: [created_by], references: [id])

  @@index([family_id])
  @@index([family_id, date])
}

model PinnedNote {
  id           String    @id @default(cuid())
  family_id    String
  title        String
  body         String
  color        String    @default("yellow") // 'yellow' | 'pink' | 'blue' | 'green' | 'purple'
  pinned       Boolean   @default(true)
  created_by   String
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  creator      User      @relation("CreatedNotes", fields: [created_by], references: [id])

  @@index([family_id])
}

model Anniversary {
  id           String    @id @default(cuid())
  family_id    String
  name         String
  type         String    // 'birthday' | 'anniversary' | 'custom'
  date         DateTime  // month + day, year is optional context
  notes        String?
  person_id    String?   // optional link to a User
  created_at   DateTime  @default(now())

  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  person       User?     @relation("FamilyAnniversaries", fields: [person_id], references: [id], onDelete: SetNull)

  @@index([family_id])
  @@index([family_id, date])
}

model FamilyLocation {
  id           String    @id @default(cuid())
  family_id    String
  user_id      String
  label        String    // 'Home', 'School', 'Work', 'Soccer practice'
  address      String?
  latitude     Float?
  longitude    Float?
  is_primary   Boolean   @default(false)  // home base
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  user         User      @relation("UserLocations", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([family_id])
  @@index([user_id])
}

model Pickup {
  id           String    @id @default(cuid())
  family_id    String
  title        String    // 'School pickup', 'Soccer practice'
  location     String?
  pickup_time  DateTime
  assigned_to  String?   // who is doing the pickup
  created_by   String
  notes        String?
  completed    Boolean   @default(false)
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  assignee     User?     @relation("AssignedPickups", fields: [assigned_to], references: [id], onDelete: SetNull)
  creator      User      @relation("CreatedPickups", fields: [created_by], references: [id])

  @@index([family_id])
  @@index([family_id, pickup_time])
  @@index([assigned_to])
}

model Allowance {
  id           String    @id @default(cuid())
  family_id    String
  from_user_id String    // parent (giver)
  to_user_id   String    // kid (receiver)
  amount       Float
  reason       String?   // 'Weekly allowance', 'Extra for good grades'
  status       String    @default("pending") // 'pending' | 'paid' | 'cancelled'
  scheduled_for DateTime?
  paid_at      DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  family       Family    @relation(fields: [family_id], references: [id], onDelete: Cascade)
  from_user    User      @relation("AllowanceFrom", fields: [from_user_id], references: [id], onDelete: Cascade)
  to_user      User      @relation("AllowanceTo", fields: [to_user_id], references: [id], onDelete: Cascade)

  @@index([family_id])
  @@index([to_user_id])
  @@index([status])
}

