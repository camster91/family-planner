# Production environment variables
# IMPORTANT: Do NOT commit real secrets to this file.
# Set DATABASE_URL and JWT_SECRET via your hosting provider's secret management.

# Database Configuration (set via environment)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret (set via environment - use a random 64+ character string)
# JWT_SECRET=your-secret-here

# Application URL
NEXT_PUBLIC_APP_URL=https://family.ashbi.ca

# Node Environment
NODE_ENV=production
