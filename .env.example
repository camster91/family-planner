# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/family_planner

# Supabase Configuration (optional, for auth)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Family Planner"

# Optional: Email Service (for Phase 2)
# RESEND_API_KEY=your_resend_api_key
# EMAIL_FROM=noreply@yourdomain.com

# Optional: Analytics (for Phase 4)
# POSTHOG_KEY=your_posthog_key
# POSTHOG_HOST=https://app.posthog.com

# Optional: Stripe (for Phase 4)
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key