# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/family_planner

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-jwt-secret-change-me

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Family Planner"

# Optional: Email Service (for Phase 2)
# RESEND_API_KEY=your_resend_api_key
# EMAIL_FROM=noreply@yourdomain.com

# Optional: Analytics (for Phase 4)
# POSTHOG_KEY=your_posthog_key
# POSTHOG_HOST=https://app.posthog.com

# Optional: Stripe (for Phase 4)
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
